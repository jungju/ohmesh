{{define "login.tmpl"}}
{{template "shell_start" .}}
<div class="row">
  <div>
    <h1>ohmesh 로그인</h1>
    <p class="muted">내 앱과 사용자 데이터 관리를 위해 ohmesh에 로그인합니다.</p>
  </div>
</div>

{{if .LoginError}}<div class="error">{{.LoginError}}</div>{{end}}

<section class="two-col">
  <div class="panel">
    <h2>OAuth 로그인</h2>
    <div class="stack">
      {{range .Providers}}
        <div class="plain-panel">
          <div class="row">
            <div>
              <strong>{{.Name}}</strong>
              {{if not .Enabled}}<br><span class="muted">{{.MissingConfig}}</span>{{end}}
            </div>
            {{if .Enabled}}
              <a class="button" href="{{.LoginURL}}">{{.Name}}로 로그인</a>
            {{else}}
              <span class="button disabled">{{.Name}} 비활성</span>
            {{end}}
          </div>
        </div>
      {{end}}
    </div>
  </div>

  <div class="plain-panel">
    <h2>앱 관리</h2>
    <p class="muted">로그인 후 앱 등록, 도메인 설정, 사용자 세션, JSON 레코드를 한 곳에서 관리합니다.</p>
  </div>
</section>
{{template "shell_end" .}}
{{end}}
