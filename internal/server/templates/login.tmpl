{{define "login.tmpl"}}
{{template "shell_start" .}}
<div class="row">
  <div>
    <h1>{{.LoginHeading}}</h1>
    <p class="muted">{{.LoginDescription}}</p>
  </div>
</div>

{{if .LoginError}}<div class="error">{{.LoginError}}</div>{{end}}

<section class="login-shell">
  <div class="panel login-card">
    {{range .Providers}}
      <a class="button login-provider" href="{{.LoginURL}}">{{.Name}}로 로그인</a>
    {{else}}
      <div class="empty">사용 가능한 로그인 방법이 없습니다.</div>
    {{end}}
  </div>
</section>
{{template "shell_end" .}}
{{end}}
