{{define "admin_app_users.tmpl"}}
{{template "shell_start" .}}
<div class="row">
  <div>
    <h1>{{.App.Name}} 사용자</h1>
    <p class="muted"><code>{{.App.Slug}}</code> 앱에 세션 또는 레코드가 있는 사용자입니다.</p>
  </div>
</div>

<div class="tabs">
  <a href="/admin/apps/{{.App.Slug}}">설정</a>
  <a class="active" href="/admin/apps/{{.App.Slug}}/users">사용자</a>
  <a href="/admin/apps/{{.App.Slug}}/db">DB</a>
</div>

{{if .Users}}
  <table>
    <thead>
      <tr><th>사용자</th><th>세션</th><th>레코드</th><th>최근 세션</th><th>최근 레코드</th><th></th></tr>
    </thead>
    <tbody>
    {{range .Users}}
      <tr>
        <td>
          <div style="display:flex; align-items:center; gap:10px;">
            {{if .AvatarURL}}<img class="avatar" src="{{.AvatarURL}}" alt="">{{else}}<span class="avatar"></span>{{end}}
            <div>
              <strong>{{if .Name}}{{.Name}}{{else}}User {{.ID}}{{end}}</strong><br>
              <span class="muted">{{.Email}}</span><br>
              <code>#{{.ID}}</code>
            </div>
          </div>
        </td>
        <td>{{.SessionCount}}</td>
        <td>{{.RecordCount}}</td>
        <td>{{if .LastSessionAt}}{{.LastSessionAt}}{{else}}-{{end}}</td>
        <td>{{if .LastRecordAt}}{{.LastRecordAt}}{{else}}-{{end}}</td>
        <td>
          <form method="post" action="/admin/apps/{{$.App.Slug}}/users/{{.ID}}/sessions/delete">
            <button class="danger" type="submit">세션 만료</button>
          </form>
        </td>
      </tr>
    {{end}}
    </tbody>
  </table>
{{else}}
  <div class="empty">아직 이 앱을 사용한 사용자가 없습니다.</div>
{{end}}
{{template "shell_end" .}}
{{end}}
