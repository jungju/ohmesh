{{define "login.tmpl"}}
{{template "shell_start" .}}
<div class="row">
  <div>
    <h1>로그인</h1>
    <p class="muted">정적 앱에서 사용할 OAuth 로그인 진입점입니다.</p>
  </div>
</div>

{{if .LoginError}}<div class="error">{{.LoginError}}</div>{{end}}

<section class="two-col">
  <div class="panel">
    <h2>앱 선택</h2>
    <form method="get" action="/login" class="stack">
      <label>
        앱
        <select name="app">
          <option value="">앱을 선택하세요</option>
          {{range .Apps}}
            <option value="{{.Slug}}" {{if eq $.AppSlug .Slug}}selected{{end}}>{{.Name}} ({{.Slug}})</option>
          {{end}}
        </select>
      </label>
      <label>
        Redirect URL
        <input name="redirect_url" value="{{.RedirectURL}}" placeholder="https://example.com/app">
      </label>
      <button type="submit">로그인 옵션 보기</button>
    </form>
  </div>

  <div class="panel">
    <h2>OAuth Provider</h2>
    {{if .AppReady}}
      <p class="muted"><strong>{{.SelectedApp.Name}}</strong> 앱으로 로그인합니다.</p>
    {{else}}
      <p class="muted">앱과 redirect URL을 먼저 선택하세요.</p>
    {{end}}
    <div class="stack">
      {{range .Providers}}
        <div class="plain-panel">
          <div class="row">
            <div>
              <strong>{{.Name}}</strong>
              {{if not .Enabled}}<br><span class="muted">{{.MissingConfig}}</span>{{end}}
            </div>
            {{if .Enabled}}
              <a class="button" href="{{.LoginURL}}">{{.Name}}로 로그인</a>
            {{else}}
              <span class="button disabled">{{.Name}} 비활성</span>
            {{end}}
          </div>
        </div>
      {{end}}
    </div>
  </div>
</section>
{{template "shell_end" .}}
{{end}}
