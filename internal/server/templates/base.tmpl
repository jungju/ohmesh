{{define "shell_start"}}
<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="alternate" type="text/plain" title="ohmesh machine-readable API guide" href="/llms.txt">
  <link rel="service-desc" type="application/openapi+json" href="/openapi.json">
  <title>{{.Title}} · ohmesh</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f7f8fb;
      --surface: #ffffff;
      --surface-strong: #f0f3f7;
      --text: #17202a;
      --muted: #647184;
      --line: #d8dee8;
      --accent: #0f766e;
      --accent-strong: #115e59;
      --danger: #b42318;
      --warn: #8a5a00;
      --shadow: 0 14px 40px rgba(23, 32, 42, 0.08);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font: 15px/1.55 system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    a { color: var(--accent-strong); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .topbar {
      position: sticky;
      top: 0;
      z-index: 10;
      background: rgba(255, 255, 255, 0.92);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(16px);
    }
    .nav {
      max-width: 1180px;
      min-height: 58px;
      margin: 0 auto;
      padding: 0 22px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--text);
      font-weight: 750;
      letter-spacing: 0;
    }
    .mark {
      width: 28px;
      height: 28px;
      border: 1px solid #89b9b4;
      border-radius: 8px;
      display: grid;
      place-items: center;
      color: var(--accent-strong);
      background: #e9f6f4;
      font-weight: 800;
    }
    .navlinks {
      display: flex;
      gap: 6px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: flex-end;
    }
    .navlinks a {
      padding: 8px 10px;
      color: var(--muted);
      border-radius: 8px;
      font-weight: 650;
    }
    .navlinks a:hover, .navlinks a.active {
      color: var(--text);
      background: var(--surface-strong);
      text-decoration: none;
    }
    .nav-logout { display: inline-flex; margin-left: 6px; }
    .icon-button {
      width: 40px;
      min-height: 40px;
      padding: 0;
      border-color: var(--line);
      background: white;
      color: var(--muted);
    }
    .icon-button:hover {
      color: var(--danger);
      border-color: #efb4ad;
      background: #fffafa;
    }
    .icon-button svg {
      width: 18px;
      height: 18px;
      stroke: currentColor;
    }
    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 22px 56px;
    }
    h1, h2, h3 { line-height: 1.15; letter-spacing: 0; }
    h1 { margin: 0 0 12px; font-size: 52px; }
    h2 { margin: 0 0 16px; font-size: 24px; }
    h3 { margin: 0 0 10px; font-size: 17px; }
    p { margin: 0 0 14px; }
    .muted { color: var(--muted); }
    .hero {
      min-height: 420px;
      display: grid;
      grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
      gap: 34px;
      align-items: center;
      padding-bottom: 28px;
    }
    .intro-hero {
      min-height: 560px;
      padding: 24px 0 42px;
    }
    .hero-copy {
      display: grid;
      gap: 14px;
      align-content: center;
    }
    .eyebrow {
      margin: 0;
      color: var(--accent-strong);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
    }
    .hero-facts, .tag-list {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-top: 6px;
    }
    .hero-facts span, .tag-list span {
      display: inline-flex;
      align-items: center;
      min-height: 30px;
      padding: 5px 10px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: white;
      color: #425066;
      font-size: 13px;
      font-weight: 750;
    }
    .intro-photo {
      margin: 0;
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--surface);
      box-shadow: var(--shadow);
    }
    .intro-photo-hero, .intro-photo-wide {
      aspect-ratio: 16 / 9;
    }
    .intro-photo img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .intro-section, .intro-split {
      border-top: 1px solid var(--line);
      padding: 42px 0;
    }
    .intro-split {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
      gap: 28px;
      align-items: center;
    }
    .intro-split-reverse {
      grid-template-columns: minmax(320px, 1.05fr) minmax(0, 0.95fr);
    }
    .intro-split-reverse .intro-photo {
      order: 2;
    }
    .intro-copy {
      max-width: 610px;
    }
    .intro-copy p:last-child {
      margin-bottom: 0;
    }
    .section-heading {
      max-width: 780px;
      margin-bottom: 22px;
    }
    .intro-list {
      display: grid;
      gap: 10px;
      margin: 18px 0 0;
      padding: 0;
      list-style: none;
    }
    .intro-list li {
      position: relative;
      padding-left: 18px;
      color: #334155;
    }
    .intro-list li::before {
      content: "";
      position: absolute;
      top: 0.72em;
      left: 0;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--accent);
    }
    .flow-showcase, .feature-layout, .quickstart {
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
      gap: 20px;
      align-items: stretch;
    }
    .flow-showcase .home-steps {
      grid-template-columns: 1fr;
      margin-bottom: 0;
    }
    .flow-showcase .step {
      min-height: auto;
    }
    .feature-layout {
      grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    }
    .feature-grid, .code-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
    .feature-card {
      background: white;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 18px;
    }
    .feature-card p {
      color: var(--muted);
      margin-bottom: 0;
    }
    .quickstart {
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    }
    .quickstart .code-grid {
      grid-template-columns: 1fr;
    }
    .quickstart pre {
      max-height: none;
    }
    .intro-note {
      margin-top: 14px;
      padding: 12px 14px;
      border: 1px solid #e8c878;
      border-radius: 8px;
      background: #fff8e5;
      color: var(--warn);
      font-weight: 650;
    }
    .intro-cta {
      display: grid;
      justify-items: start;
      gap: 4px;
      margin-top: 6px;
      padding: 34px 0 8px;
      border-top: 1px solid var(--line);
    }
    .intro-cta p {
      max-width: 640px;
      color: var(--muted);
    }
    .lede {
      color: #3f4d5d;
      font-size: 18px;
      max-width: 660px;
    }
    .lede.hero-lede {
      max-width: 620px;
      font-size: 20px;
    }
    .actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 22px;
    }
    .button, button {
      border: 1px solid var(--accent);
      background: var(--accent);
      color: white;
      min-height: 40px;
      padding: 9px 14px;
      border-radius: 8px;
      font-weight: 720;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font: inherit;
    }
    .button:hover { background: var(--accent-strong); text-decoration: none; }
    .button.secondary, button.secondary {
      background: white;
      color: var(--accent-strong);
      border-color: var(--line);
    }
    .button.danger, button.danger {
      background: white;
      color: var(--danger);
      border-color: #efb4ad;
    }
    .button.disabled {
      background: var(--surface-strong);
      border-color: var(--line);
      color: var(--muted);
      cursor: not-allowed;
    }
    .panel {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
      box-shadow: var(--shadow);
      padding: 22px;
    }
    .plain-panel {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 20px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }
    .two-col {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      align-items: start;
    }
    .metric {
      background: white;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 16px;
    }
    .metric strong {
      display: block;
      font-size: 28px;
      line-height: 1.1;
    }
    .guide-hero {
      background: white;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 28px;
      margin: 18px 0 24px;
    }
    .guide-hero strong {
      display: block;
      color: var(--accent-strong);
      font-size: 42px;
      line-height: 1.05;
      margin-bottom: 8px;
    }
    .steps {
      counter-reset: step;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }
    .home-steps {
      gap: 18px;
      margin-bottom: 28px;
    }
    .step {
      position: relative;
      min-height: 150px;
      background: white;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 18px;
    }
    .home-steps .step {
      min-height: 220px;
      padding: 20px;
      display: flex;
      flex-direction: column;
    }
    .home-steps .step p { flex: 1; }
    .step::before {
      counter-increment: step;
      content: counter(step);
      display: inline-grid;
      place-items: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #e9f6f4;
      color: var(--accent-strong);
      font-weight: 800;
      margin-bottom: 12px;
    }
    .home-summary {
      gap: 20px;
      margin-top: 2px;
      align-items: stretch;
    }
    .home-summary .plain-panel {
      min-height: 160px;
      padding: 22px;
    }
    .map {
      display: grid;
      gap: 12px;
    }
    .node {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 14px;
      background: white;
    }
    .node.main {
      background: #e9f6f4;
      border-color: #89b9b4;
    }
    .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }
    .stack { display: grid; gap: 16px; }
    .login-shell {
      max-width: 520px;
      margin: 30px auto 0;
    }
    .login-card {
      display: grid;
      gap: 12px;
    }
    .login-provider {
      width: 100%;
      min-height: 46px;
    }
    .toolbar {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }
    .toolbar label { min-width: min(420px, 100%); }
    .record-filter-panel {
      margin-top: 18px;
    }
    .filter-form {
      display: grid;
      grid-template-columns: minmax(220px, 1.45fr) minmax(220px, 1.45fr) minmax(140px, 0.7fr) auto;
      gap: 14px;
      align-items: end;
    }
    .filter-actions {
      display: flex;
      align-items: flex-end;
    }
    .filter-actions button {
      width: 100%;
      white-space: nowrap;
    }
    .inline-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    .section {
      margin-top: 22px;
    }
    .subtle-band {
      background: var(--surface);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 18px 0;
    }
    .modal-dialog {
      width: min(680px, calc(100vw - 32px));
      max-height: calc(100dvh - 32px);
      border: 1px solid var(--line);
      border-radius: 8px;
      box-shadow: 0 24px 70px rgba(23, 32, 42, 0.22);
      padding: 0;
      color: var(--text);
      overflow: auto;
    }
    .modal-dialog.wide-dialog {
      width: min(920px, calc(100vw - 32px));
    }
    .modal-dialog::backdrop {
      background: rgba(23, 32, 42, 0.36);
      backdrop-filter: blur(2px);
    }
    .modal-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 22px 22px 14px;
      border-bottom: 1px solid var(--line);
    }
    .modal-header h2 { margin-bottom: 6px; }
    .modal-form { padding: 22px; }
    .modal-actions {
      justify-content: flex-end;
      margin-top: 4px;
    }
    .prompt-body {
      display: grid;
      gap: 14px;
    }
    .prompt-textarea {
      min-height: 460px;
      line-height: 1.5;
      resize: vertical;
    }
    .danger-zone {
      border-color: #efb4ad;
      background: #fffafa;
    }
    .table-form {
      display: grid;
      gap: 8px;
      min-width: 260px;
    }
    .table-form textarea {
      min-height: 110px;
    }
    .tabs {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin: 14px 0 20px;
    }
    .tabs a {
      padding: 8px 10px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: white;
      color: var(--muted);
      font-weight: 650;
    }
    .tabs a.active {
      color: var(--accent-strong);
      border-color: #89b9b4;
      background: #e9f6f4;
    }
    form { margin: 0; }
    label {
      display: grid;
      gap: 6px;
      color: #334155;
      font-weight: 650;
    }
    input, select, textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: white;
      color: var(--text);
      padding: 10px 11px;
      font: inherit;
    }
    textarea {
      min-height: 160px;
      font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
      font-size: 13px;
    }
    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
    .form-grid .wide { grid-column: 1 / -1; }
    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
    }
    th, td {
      border-bottom: 1px solid var(--line);
      padding: 11px 12px;
      text-align: left;
      vertical-align: top;
    }
    th {
      background: var(--surface-strong);
      color: #425066;
      font-size: 13px;
    }
    tr:last-child td { border-bottom: 0; }
    code, pre {
      font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
      font-size: 13px;
    }
    pre {
      white-space: pre-wrap;
      word-break: break-word;
      margin: 0;
      background: #f7fafc;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 10px;
      max-height: 260px;
      overflow: auto;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      min-height: 26px;
      padding: 3px 8px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: var(--surface-strong);
      color: #425066;
      font-size: 13px;
      font-weight: 700;
    }
    .pill.active { background: #e9f6f4; border-color: #89b9b4; color: var(--accent-strong); }
    .pill.disabled { background: #fff2f0; border-color: #efb4ad; color: var(--danger); }
    .notice, .error, .warning {
      border-radius: 8px;
      padding: 12px 14px;
      margin-bottom: 16px;
      border: 1px solid var(--line);
      background: white;
    }
    .notice { border-color: #89b9b4; background: #e9f6f4; color: var(--accent-strong); }
    .error { border-color: #efb4ad; background: #fff2f0; color: var(--danger); }
    .warning { border-color: #e8c878; background: #fff8e5; color: var(--warn); }
    .avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      object-fit: cover;
      border: 1px solid var(--line);
      background: var(--surface-strong);
    }
    .empty {
      padding: 26px;
      border: 1px dashed var(--line);
      border-radius: 8px;
      color: var(--muted);
      background: white;
    }
    @media (max-width: 860px) {
      h1 { font-size: 40px; }
      .hero, .two-col, .grid, .form-grid, .filter-form, .steps, .intro-split, .flow-showcase, .feature-layout, .quickstart { grid-template-columns: 1fr; }
      .intro-hero { min-height: auto; }
      .intro-section, .intro-split { padding: 32px 0; }
      .intro-split-reverse .intro-photo { order: 0; }
      .feature-grid, .code-grid { grid-template-columns: 1fr; }
      .nav { align-items: flex-start; flex-direction: column; padding-top: 12px; padding-bottom: 12px; }
      main { padding-top: 24px; }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <nav class="nav" aria-label="Main navigation">
      <a class="brand" href="/"><span class="mark">o</span><span>ohmesh</span></a>
      <div class="navlinks">
        <a href="/" {{if eq .CurrentPath "/"}}class="active"{{end}}>소개</a>
        {{if .IsLoggedIn}}
          <a href="/dashboard" {{if .DashboardNavActive}}class="active"{{end}}>대시보드</a>
          <a href="/admin/apps" {{if .AdminNavActive}}class="active"{{end}}>앱 관리</a>
        {{else}}
          <a href="/login" {{if eq .CurrentPath "/login"}}class="active"{{end}}>로그인</a>
        {{end}}
        {{if .IsLoggedIn}}
          <form class="nav-logout" method="post" action="/logout">
            <button class="icon-button" type="submit" aria-label="로그아웃" title="로그아웃">
              <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                <path d="M16 17l5-5-5-5"></path>
                <path d="M21 12H9"></path>
              </svg>
            </button>
          </form>
        {{end}}
      </div>
    </nav>
  </header>
  <main>
    {{if .Notice}}<div class="notice">{{.Notice}}</div>{{end}}
{{end}}

{{define "shell_end"}}
  </main>
</body>
</html>
{{end}}
